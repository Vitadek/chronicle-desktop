{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Chronicle",
  "version": "0.1.0",
  "identifier": "ink.chronicler.Chronicle",
  "build": {
    "frontendDist": "../splash"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png"
    ],
    "resources": {
      "resources/chronicle": "chronicle"
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      }
    }
  }
}
